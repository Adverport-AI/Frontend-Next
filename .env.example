# ─── Sanity CMS ────────────────────────────────────────────────────────────────
# Sanity Dashboard: https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity API Token (okuma + yazma yetkisi; Settings > API > Tokens)
SANITY_API_TOKEN=your_sanity_api_token_here

# Sanity Webhook Secret (Settings > API > Webhooks > Secret)
# Webhook URL: https://adverport.com/api/revalidate?secret=BURAYA_YAZ
SANITY_WEBHOOK_SECRET=gizli_rastgele_string_buraya

# ─── Airtable ──────────────────────────────────────────────────────────────────
# Airtable Dashboard: https://airtable.com
# API Key: https://airtable.com/create/tokens
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Contacts
